# Web app
PORT=8080

# Ketel Mail start standaard live. Zet dit alleen op true als je demo-mails wilt bekijken.
DEMO_MODE=false

MAILBOX_USER=
MAILBOX_PASSWORD=

IMAP_HOST=imappro.zoho.eu
IMAP_PORT=993
IMAP_SECURE=true

SMTP_HOST=smtppro.zoho.eu
SMTP_PORT=465
SMTP_SECURE=true
MAIL_FROM=

# Translation
# Portable/offline vertalen: start LibreTranslate lokaal.
TRANSLATE_PROVIDER=libretranslate
TRANSLATE_URL=http://127.0.0.1:5000
TRANSLATE_API_KEY=
