# Web app
PORT=8080

# Start veilig in demo-modus. Zet via de Ketel Mail instellingen echte IMAP/SMTP in.
DEMO_MODE=true

# Real mailbox mode:
# DEMO_MODE=false

MAILBOX_USER=
MAILBOX_PASSWORD=

IMAP_HOST=
IMAP_PORT=993
IMAP_SECURE=true

SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
MAIL_FROM=

# Translation
TRANSLATE_PROVIDER=mymemory
TRANSLATE_URL=http://127.0.0.1:5000
TRANSLATE_API_KEY=
