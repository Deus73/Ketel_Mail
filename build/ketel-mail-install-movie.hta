<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <title>Ketel Mail wordt geinstalleerd</title>
    <hta:application
      applicationname="Ketel Mail installatie"
      border="thin"
      caption="yes"
      contextmenu="no"
      maximizebutton="no"
      minimizebutton="no"
      scroll="no"
      singleinstance="yes"
      sysmenu="yes"
      windowstate="normal"
    />
    <style>
      html,
      body {
        width: 920px;
        height: 560px;
        margin: 0;
        overflow: hidden;
        background: #120717;
        color: #fff7fb;
        font-family: "Segoe UI", Arial, sans-serif;
      }

      .stage {
        position: relative;
        width: 920px;
        height: 560px;
        background:
          radial-gradient(circle at 16% 12%, rgba(255, 92, 154, 0.25), transparent 190px),
          radial-gradient(circle at 82% 18%, rgba(68, 221, 202, 0.17), transparent 180px),
          linear-gradient(145deg, #1c0c22, #09050d 68%);
      }

      .title {
        position: absolute;
        left: 34px;
        top: 26px;
      }

      h1 {
        margin: 0 0 6px;
        font-size: 34px;
        line-height: 1;
      }

      p {
        margin: 0;
        color: #d9c3dd;
        font-size: 16px;
      }

      .room {
        position: absolute;
        left: 26px;
        right: 26px;
        bottom: 34px;
        height: 380px;
        border: 1px solid rgba(255, 189, 219, 0.24);
        border-radius: 18px;
        background:
          linear-gradient(180deg, rgba(255, 255, 255, 0.055), rgba(255, 255, 255, 0.018)),
          rgba(255, 255, 255, 0.035);
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.34);
      }

      .floor {
        position: absolute;
        left: 0;
        right: 0;
        bottom: 0;
        height: 104px;
        border-radius: 0 0 18px 18px;
        background: linear-gradient(180deg, rgba(255, 209, 102, 0.09), rgba(0, 0, 0, 0.18));
      }

      .chair {
        position: absolute;
        left: 82px;
        bottom: 96px;
        width: 238px;
        height: 106px;
        border: 4px solid #5f2368;
        border-radius: 22px 22px 12px 12px;
        background: linear-gradient(135deg, #33143b, #1b0b22);
        box-shadow: inset 0 12px 22px rgba(255, 255, 255, 0.06);
      }

      .chair:before {
        content: "";
        position: absolute;
        left: 22px;
        right: 22px;
        top: -72px;
        height: 90px;
        border: 4px solid #5f2368;
        border-radius: 30px 30px 12px 12px;
        background: #24102d;
      }

      .person {
        position: absolute;
        left: 148px;
        bottom: 172px;
        width: 142px;
        height: 190px;
        transform: rotate(-10deg);
        transform-origin: 50% 100%;
        animation: slump 2.6s ease-in-out infinite;
      }

      .head {
        position: absolute;
        left: 42px;
        top: 0;
        width: 64px;
        height: 64px;
        border: 4px solid #ffd166;
        border-radius: 50%;
        background: #ffc47a;
      }

      .eye {
        position: absolute;
        top: 25px;
        width: 10px;
        height: 4px;
        border-radius: 999px;
        background: #38133c;
      }

      .eye.left {
        left: 15px;
      }

      .eye.right {
        right: 15px;
      }

      .mouth {
        position: absolute;
        left: 23px;
        bottom: 14px;
        width: 19px;
        height: 5px;
        border-radius: 999px;
        background: #38133c;
        opacity: 0.7;
      }

      .body {
        position: absolute;
        left: 25px;
        top: 66px;
        width: 98px;
        height: 94px;
        border: 5px solid #ff5c9a;
        border-radius: 22px;
        background: linear-gradient(135deg, #ff5c9a, #6f2372);
      }

      .arm {
        position: absolute;
        left: 112px;
        top: 82px;
        width: 122px;
        height: 22px;
        border-radius: 999px;
        background: #ffc47a;
        transform-origin: 0 50%;
        transform: rotate(16deg);
        animation: lazyThrow 7.4s linear forwards;
      }

      .leg {
        position: absolute;
        top: 158px;
        width: 88px;
        height: 21px;
        border-radius: 999px;
        background: #44ddca;
      }

      .leg.one {
        left: 0;
        transform: rotate(16deg);
      }

      .leg.two {
        left: 64px;
        transform: rotate(-8deg);
      }

      .bin {
        position: absolute;
        right: 102px;
        bottom: 86px;
        width: 132px;
        height: 164px;
        border: 7px solid #44ddca;
        border-top: 16px solid #44ddca;
        border-radius: 12px 12px 28px 28px;
        background: linear-gradient(180deg, rgba(68, 221, 202, 0.16), rgba(68, 221, 202, 0.04));
        box-shadow: 0 0 24px rgba(68, 221, 202, 0.18);
      }

      .bin:before {
        content: "";
        position: absolute;
        left: -22px;
        right: -22px;
        top: -28px;
        height: 15px;
        border-radius: 999px;
        background: #44ddca;
      }

      .bin-label {
        position: absolute;
        right: 88px;
        bottom: 260px;
        width: 180px;
        color: #44ddca;
        font-size: 20px;
        font-weight: 900;
        text-align: center;
        text-shadow: 0 0 16px rgba(68, 221, 202, 0.55);
      }

      .throw-line {
        position: absolute;
        left: 365px;
        top: 132px;
        width: 332px;
        height: 145px;
        border-top: 4px dashed rgba(255, 209, 102, 0.42);
        border-radius: 50%;
        transform: rotate(-9deg);
      }

      .paper {
        position: absolute;
        left: 360px;
        top: 214px;
        width: 34px;
        height: 34px;
        border: 3px solid #fff7fb;
        border-radius: 45% 55% 48% 52%;
        background: linear-gradient(135deg, #ffffff, #d9c3dd);
        box-shadow: 0 0 18px rgba(255, 255, 255, 0.26);
        animation: throwBall 7.4s linear forwards;
      }

      .paper:after {
        content: "";
        position: absolute;
        inset: 8px 5px 5px 8px;
        border-left: 2px solid rgba(95, 35, 104, 0.45);
        border-top: 2px solid rgba(95, 35, 104, 0.45);
        transform: rotate(23deg);
      }

      .attempt {
        position: absolute;
        left: 350px;
        bottom: 48px;
        min-width: 230px;
        padding: 12px 16px;
        border: 2px solid rgba(255, 209, 102, 0.55);
        border-radius: 12px;
        background: rgba(255, 209, 102, 0.09);
        color: #ffd166;
        font-size: 18px;
        font-weight: 800;
        text-align: center;
      }

      .result {
        position: absolute;
        right: 80px;
        bottom: 44px;
        width: 230px;
        color: #fff7fb;
        font-size: 15px;
        font-weight: 750;
        text-align: center;
      }

      .progress {
        position: absolute;
        left: 34px;
        right: 34px;
        bottom: 20px;
        height: 12px;
        border: 1px solid rgba(255, 189, 219, 0.22);
        border-radius: 999px;
        overflow: hidden;
        background: rgba(255, 255, 255, 0.05);
      }

      .bar {
        width: 0%;
        height: 100%;
        background: linear-gradient(90deg, #ff5c9a, #44ddca, #ffd166);
        animation: fill 7.4s linear forwards;
      }

      @keyframes slump {
        0%, 100% { transform: rotate(-10deg) translateY(0); }
        50% { transform: rotate(-13deg) translateY(5px); }
      }

      @keyframes lazyThrow {
        0%, 12%, 30%, 45%, 63%, 78% { transform: rotate(16deg); }
        18%, 51%, 84% { transform: rotate(-22deg); }
      }

      @keyframes throwBall {
        0% { left: 360px; top: 214px; opacity: 1; transform: rotate(0deg) scale(1); }
        17% { left: 584px; top: 128px; transform: rotate(230deg) scale(1.1); }
        27% { left: 682px; top: 332px; transform: rotate(420deg) scale(0.95); }
        32% { left: 360px; top: 214px; transform: rotate(0deg) scale(1); }
        50% { left: 578px; top: 116px; transform: rotate(260deg) scale(1.1); }
        60% { left: 748px; top: 330px; transform: rotate(460deg) scale(0.95); }
        65% { left: 360px; top: 214px; transform: rotate(0deg) scale(1); }
        84% { left: 660px; top: 132px; transform: rotate(270deg) scale(1.12); }
        94%, 100% { left: 715px; top: 292px; opacity: 1; transform: rotate(540deg) scale(0.85); }
      }

      @keyframes fill {
        from { width: 0%; }
        to { width: 100%; }
      }
    </style>
  </head>
  <body>
    <div class="stage">
      <div class="title">
        <h1>Ketel Mail wordt geinstalleerd</h1>
        <p>Even geduld. Hij probeert het op zijn eigen tempo.</p>
      </div>
      <div class="room">
        <div class="floor"></div>
        <div class="chair"></div>
        <div class="person">
          <div class="head">
            <span class="eye left"></span>
            <span class="eye right"></span>
            <span class="mouth"></span>
          </div>
          <div class="body"></div>
          <div class="arm"></div>
          <div class="leg one"></div>
          <div class="leg two"></div>
        </div>
        <div class="throw-line"></div>
        <div class="paper"></div>
        <div class="bin-label">PRULLENBAK</div>
        <div class="bin"></div>
        <div class="attempt" id="attempt">Poging 1... te lui gemikt</div>
        <div class="result" id="result">Je ziet hem drie keer gooien. De derde is raak.</div>
      </div>
      <div class="progress"><div class="bar"></div></div>
    </div>

    <script type="text/javascript">
      window.resizeTo(936, 600);
      var attempt = document.getElementById("attempt");
      var result = document.getElementById("result");
      setTimeout(function () {
        attempt.innerText = "Poging 2... net ernaast";
        result.innerText = "Nog niet. Hij doet alsof dit gepland was.";
      }, 2600);
      setTimeout(function () {
        attempt.innerText = "Poging 3... RAAK";
        result.innerText = "Raak. Ketel Mail is klaar om te starten.";
      }, 5250);
      setTimeout(function () { window.close(); }, 7700);
    </script>
  </body>
</html>
