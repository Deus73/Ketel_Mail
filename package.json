{
  "name": "ketel-mail",
  "version": "0.1.0",
  "description": "Zelf-hostbare webmail-app met desktopvenster voor Ketel Mail.",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "server": "node server/index.js",
    "start": "node server/index.js",
    "desktop": "npm run build && electron .",
    "desktop:fast": "electron .",
    "pack:desktop": "npm run build && electron-builder --dir",
    "dist:desktop": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win nsis portable",
    "dist:linux": "npm run build && electron-builder --linux AppImage deb",
    "dist:mac": "npm run build && electron-builder --mac dmg zip",
    "screenshots": "electron scripts/capture-screenshots.cjs",
    "setup:debian": "sh ./install-debian-parrot.sh"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Deus73/Ketel_Mail.git"
  },
  "bugs": {
    "url": "https://github.com/Deus73/Ketel_Mail/issues"
  },
  "homepage": "https://github.com/Deus73/Ketel_Mail#readme",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "compression": "^1.8.1",
    "express": "^5.1.0",
    "franc-min": "^6.2.0",
    "imapflow": "^1.0.194",
    "lucide-react": "^0.468.0",
    "mailparser": "^3.7.2",
    "nodemailer": "^9.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sanitize-html": "^2.17.5",
    "vite": "^8.0.16"
  },
  "devDependencies": {
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.ketelmail.desktop",
    "productName": "Ketel Mail",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "server/**/*",
      "electron/**/*",
      "public/icons/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "electron/main.cjs"
    },
    "win": {
      "icon": "public/icons/ketel-mail-icon.png",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "icon": "public/icons/ketel-mail-icon.png",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Network"
    },
    "mac": {
      "icon": "public/icons/ketel-mail-icon.png",
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
